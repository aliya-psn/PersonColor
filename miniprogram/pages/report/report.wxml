<navigation-bar title="完整报告" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<elegant-bg></elegant-bg>
<scroll-view class="scrollarea" scroll-y>
  <view class="report-page" wx:if="{{resultInfo}}">
    <view class="content-card">
      <view class="card-user">
        <image class="card-user-avatar" src="{{userAvatar}}" mode="aspectFill"></image>
        <text class="card-user-nickname">{{userNickname}}</text>
      </view>
      <view class="label-box">人格底色</view>
      <text class="type-name">{{resultInfo.name}}</text>
      <text class="type-tagline">{{resultInfo.tagline}}</text>
    </view>
    <view class="content-card">
      <view class="label-box">人格类型</view>
      <view class="tag-list">
        <view class="tag-item" wx:for="{{resultInfo.tags}}" wx:key="*this">
          {{item}}
        </view>
      </view>
      <view class="point-list">
        <view class="point-item">
          <view class="point-num">1</view>
          <text class="point-text">
            <text class="point-label">整体气质：</text>
            {{resultInfo.summary}}
          </text>
        </view>
        <view class="point-item">
          <view class="point-num">2</view>
          <text class="point-text">
            <text class="point-label">核心优势：</text>
            {{resultInfo.strengths}}
          </text>
        </view>
        <view class="point-item">
          <view class="point-num">3</view>
          <text class="point-text">
            <text class="point-label">隐藏天赋 & 雷区：</text>
            {{resultInfo.hiddenTalent}}；{{resultInfo.weakness}}
          </text>
        </view>
        <view class="point-item">
          <view class="point-num">4</view>
          <view class="point-text">
            <text class="point-label">行动建议：</text>
            <view class="suggest-list">
              <view
                class="suggest-item"
                wx:for="{{resultInfo.suggestions}}"
                wx:key="*this"
              >
                <view class="suggest-dot"></view>
                <text class="suggest-text">{{item}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="content-card radar-card" wx:if="{{radarTitle}}">
      <view class="label-box">{{radarTitle}}</view>
      <view class="radar-wrap" wx:if="{{radarScores && radarScores.length === 4}}">
        <canvas canvas-id="radarCanvas" id="radar-canvas" class="radar-canvas" style="width: 560rpx; height: 560rpx;"></canvas>
      </view>
      <view class="radar-placeholder" wx:else>
        <text class="radar-placeholder-text">完成「{{radarTitle}}」测试后此处将显示雷达图</text>
      </view>
    </view>
    <view class="btn-area">
      <view class="btn-row">
        <view class="btn-primary" bindtap="onGenerateImage">生成图片</view>
        <view class="btn-secondary" bindtap="onTestAgain">再测一次</view>
      </view>
    </view>
  </view>
</scroll-view>
