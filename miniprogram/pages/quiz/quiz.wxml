<navigation-bar title="{{title}}" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<elegant-bg></elegant-bg>
<view class="quiz-page">
  <view class="quiz-header">
    <view class="quiz-header-top">
      <view class="quiz-badge">测评中</view>
      <view class="quiz-meta">
        <text class="progress-text">第 {{currentIndex + 1}} / {{questions.length}} 题</text>
        <text class="progress-percent">{{progress}}%</text>
      </view>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
  </view>
  <view class="question-area">
    <view class="question-container {{animating ? 'animating' : ''}} {{slideDirection}}" wx:if="{{questions[currentIndex]}}">
      <view class="question-card">
        <view class="question-header">
          <view class="question-number-badge">
            <text class="question-number-text">{{currentIndex + 1}}</text>
          </view>
          <text class="question-kicker">问题</text>
        </view>
        <text class="question-text">{{questions[currentIndex].text}}</text>
        <view class="question-decoration"></view>
      </view>
      <view class="options-head">
        <view class="options-label-wrapper">
          <text class="options-icon">✨</text>
          <text class="options-label">请选择最符合你的选项</text>
        </view>
      </view>
      <view class="options">
        <view
          wx:for="{{questions[currentIndex].options}}"
          wx:key="key"
          wx:for-index="optIndex"
          class="option-card option-card-{{optIndex}}"
          data-type="{{item.type}}"
          bindtap="onSelect"
          hover-class="option-card--hover"
          hover-stay-time="80"
        >
          <view class="option-key-wrap">
            <text class="option-key">{{item.key}}</text>
          </view>
          <view class="option-content">
            <text class="option-text">{{item.text}}</text>
          </view>
          <text class="option-chevron">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
