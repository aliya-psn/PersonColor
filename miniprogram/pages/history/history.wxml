<navigation-bar title="测试记录" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<elegant-bg></elegant-bg>
<scroll-view class="history-page" scroll-y>
  <view class="history-content">
    <view wx:if="{{!isEmpty}}" class="history-header">
      <text class="history-title">我的测试记录</text>
      <text class="history-count">共 {{historyList.length}} 条</text>
    </view>
    <view wx:if="{{isEmpty}}" class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无测试记录</text>
      <text class="empty-desc">完成测试后，记录会自动保存到这里</text>
    </view>
    <view wx:if="{{!isEmpty}}" class="history-list">
      <view
        wx:for="{{historyList}}"
        wx:key="id"
        class="history-item"
        bindtap="onItemTap"
        data-index="{{index}}"
      >
        <view class="item-header">
          <view class="item-type-badge item-type-{{item.testType}}">
            <text class="type-text">{{item.testTypeTitle}}</text>
          </view>
          <text class="item-time">{{item.timeStr}}</text>
        </view>
        <view class="item-content">
          <text class="item-result-name">{{item.resultName}}</text>
          <text class="item-result-summary">{{item.resultSummary}}</text>
        </view>
        <text class="item-arrow">›</text>
      </view>
    </view>
    <view wx:if="{{!isEmpty}}" class="history-footer">
      <view class="clear-btn" bindtap="onClear">
        <text class="clear-text">清空记录</text>
      </view>
    </view>
  </view>
</scroll-view>

